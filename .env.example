# LLM API 配置 (ModelScope Qwen)
OPENAI_COMPAT_BASE_URL=https://api-inference.modelscope.cn/v1
OPENAI_COMPAT_MODEL=Qwen/Qwen3.5-27B
OPENAI_COMPAT_API_KEY=your-api-key-here

# 可选：HuggingFace Embedding 模型缓存目录
HF_HOME=./storage/hf_cache

# Supabase 配置（可选，用于加速股票搜索）
# 如果不配置，会使用本地 CSV 搜索
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
